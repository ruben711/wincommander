# =============================================================
# WinCommander — environment variables
# =============================================================
# Alles is optioneel. Zonder env vars werkt de basisapp 100% client-side
# (oefeningen, terminal, grader, XP). Server-features (leaderboard, admin,
# notificaties, Discord-logging) activeren zodra de juiste vars ingevuld zijn.

# ─── Discord logging (optioneel) ────────────────────────────
# Server > kanaal > Integrations > Webhooks > New Webhook > Copy URL
DISCORD_WEBHOOK_URL=

# Optioneel: vereist X-Log-Secret header op /api/log (anti-misbruik)
LOG_SECRET=

# ─── Leaderboard (Upstash Redis) ────────────────────────────
# Gratis tier: 10k commands/dag, 256MB.
# 1) Maak account op https://console.upstash.com
# 2) Create Database > Region: eu-west-1 (of dichtst bij Vercel)
# 3) Kopieer "UPSTASH_REDIS_REST_URL" en "UPSTASH_REDIS_REST_TOKEN"
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Alternatief: Vercel KV injecteert KV_REST_API_URL / KV_REST_API_TOKEN — die worden ook gelezen.

# ─── Admin login (verborgen /admin) ─────────────────────────
# ADMIN_PASSWORD = je geheime wachtwoord.
# ADMIN_SECRET   = willekeurige lange string voor cookie-signing.
# Genereer ADMIN_SECRET bv. met: openssl rand -hex 32
ADMIN_PASSWORD=
ADMIN_SECRET=
